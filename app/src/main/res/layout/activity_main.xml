<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Overlay de bounding boxes -->
    <com.travessia.segura.ui.OverlayView
        android:id="@+id/overlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Indicador de estado visual (topo) -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:background="#AA000000"
        android:padding="8dp"
        android:gravity="center_vertical">

        <View
            android:id="@+id/statusDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@android:color/holo_red_dark"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvAlertStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Aguardando..."
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvFps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 FPS"
            android:textColor="#AAAAAA"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Painel inferior -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#CC000000"
        android:padding="16dp">

        <!-- Linha: Estado + Situação -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/tvEstado"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="INATIVO"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSituacao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="---"
                android:textColor="#888888"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingStart="12dp"
                android:paddingEnd="4dp" />
        </LinearLayout>

        <!-- Info -->
        <TextView
            android:id="@+id/tvInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Carregando modelo..."
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:paddingBottom="12dp" />

        <!-- Contagem de detecções -->
        <TextView
            android:id="@+id/tvDetectionCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:paddingBottom="8dp" />

        <!-- Botões -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnToggle"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="3"
                android:layout_marginEnd="8dp"
                android:text="▶ INICIAR ANÁLISE"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:enabled="false" />

            <Button
                android:id="@+id/btnConfig"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="⚙"
                android:textSize="24sp"
                android:textColor="#FFFFFF"
                android:textAllCaps="false" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>